# ============================================================
# Cima — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ---- Database (Neon PostgreSQL) -----
# Get from: https://console.neon.tech → your project → Connection string
# Format: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=postgres://your_user:your_password@your-project.neon.tech/cima?sslmode=require

# ---- Auth ----------------------------
# Long random string — generate with: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES=30d

# ---- Server --------------------------
PORT=3001
NODE_ENV=development

# ---- CORS (comma-separated) ----------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Optional: query logging ---------
LOG_QUERIES=false
