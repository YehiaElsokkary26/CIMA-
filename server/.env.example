# ============================================================
# Cima — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ---- Supabase -------------------------
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---- Database (Supabase PostgreSQL) ---
# Use the "Transaction" pooler (port 6543) — found in:
# Supabase Dashboard → Settings → Database → Connection string → URI (toggle "Transaction mode")
# Format: postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres.your-project-ref:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ---- Server ---------------------------
PORT=3001
NODE_ENV=development

# ---- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Optional: query logging ----------
LOG_QUERIES=false
